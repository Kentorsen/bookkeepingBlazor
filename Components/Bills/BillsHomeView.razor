@using BookkeepingBlazor.Pages

<div class="bill-app">
    <section class="region1">
        <button class="r1-arrow" @onclick="GoPrevious" aria-label="上一项">‹</button>

        <div class="r1-center"
             @onpointerdown="HandleDatePointerDown"
             @onpointerup="HandleDatePointerUp"
             @onpointerleave="HandleDatePointerLeave"
             @onclick="HandleDateAreaClick">
            <div class="r1-title">@CurrentDisplayTitle</div>
            <div class="r1-mode-line">
                <span class="r1-mode">@((CurrentMode == PeriodMode.Month) ? "按月" : "按日")</span>
                <span class="r1-tip">（单击选择，长按切换）</span>
            </div>
        </div>

        <button class="r1-arrow" @onclick="GoNext" aria-label="下一项">›</button>
    </section>

    @if (ShowPicker)
    {
        <div class="picker-panel">
            <div class="picker-input-wrapper">
                @if (CurrentMode == PeriodMode.Month)
                {
                    <input type="month" class="picker-input" value="@MonthPickerValue" @onchange="OnMonthPickerChanged" />
                }
                else
                {
                    <input type="date" class="picker-input" value="@DayPickerValue" @onchange="OnDayPickerChanged" />
                }
            </div>

            <div class="picker-actions">
                <button class="picker-btn light" @onclick="CancelPicker">取消</button>
                <button class="picker-btn primary" @onclick="ConfirmPickerAsync">确定</button>
            </div>
        </div>
    }

    <section class="region2"
             @onpointerdown="HandleSummaryPointerDown"
             @onpointerup="HandleSummaryPointerUp"
             @onpointerleave="HandleSummaryPointerLeave">
        <div class="r2-head">
            <div class="r2-dots">
                <button class="dot @(CurrentSummaryPage == SummaryPage.Expense ? "active" : "")"
                        @onclick="@(() => SetSummaryPage(SummaryPage.Expense))"></button>
                <button class="dot @(CurrentSummaryPage == SummaryPage.Income ? "active" : "")"
                        @onclick="@(() => SetSummaryPage(SummaryPage.Income))"></button>
            </div>

            <button class="collapse-btn" @onclick="ToggleSummaryCollapsed">
                @(IsSummaryCollapsed ? "展开" : "收起")
            </button>
        </div>

        @if (!IsSummaryCollapsed)
        {
            <div class="r2-viewport">
                <div class="r2-slider @(CurrentSummaryPage == SummaryPage.Income ? "income-page" : "expense-page")">
                    <section class="r2-page">
                        <div class="r2-title">支出</div>

                        <div class="r2-person-row">
                            <div class="r2-left">
                                <div class="r2-name">@NameYiyi</div>
                                <div class="r2-line">个人付款 @Fmt(Summary.ExpenseYiyiPersonal)</div>
                            </div>
                            <div class="r2-right">
                                <div class="r2-total-label">总支出</div>
                                <div class="r2-total expense">@Fmt(Summary.YiyiExpenseTotal)</div>
                            </div>
                        </div>

                        <div class="r2-person-row">
                            <div class="r2-left">
                                <div class="r2-name">@NameYiyi2</div>
                                <div class="r2-line">个人付款 @Fmt(Summary.ExpenseYiyi2Personal)</div>
                            </div>
                            <div class="r2-right">
                                <div class="r2-total-label">总支出</div>
                                <div class="r2-total expense">@Fmt(Summary.Yiyi2ExpenseTotal)</div>
                            </div>
                        </div>

                        <div class="r2-footer">
                            共同支出：@Fmt(Summary.SharedExpense)
                            <span class="r2-footer-note">（每人分摊 @Fmt(Summary.SharedExpenseHalf)）</span>
                        </div>
                    </section>

                    <section class="r2-page">
                        <div class="r2-title">收入 / 结余</div>

                        <div class="r2-person-row">
                            <div class="r2-left">
                                <div class="r2-name">@NameYiyi</div>
                                <div class="r2-line">个人收入 @Fmt(Summary.IncomeYiyiPersonal)</div>
                            </div>
                            <div class="r2-right">
                                <div class="r2-total-label">结余</div>
                                <div class="r2-total income">@Fmt(Summary.YiyiBalance)</div>
                            </div>
                        </div>

                        <div class="r2-person-row">
                            <div class="r2-left">
                                <div class="r2-name">@NameYiyi2</div>
                                <div class="r2-line">个人收入 @Fmt(Summary.IncomeYiyi2Personal)</div>
                            </div>
                            <div class="r2-right">
                                <div class="r2-total-label">结余</div>
                                <div class="r2-total income">@Fmt(Summary.Yiyi2Balance)</div>
                            </div>
                        </div>

                        <div class="r2-footer">
                            共同收入：@Fmt(Summary.SharedIncome)
                            <span class="r2-footer-note">（每人分摊 @Fmt(Summary.SharedIncomeHalf)）</span>
                        </div>
                    </section>
                </div>
            </div>
        }
    </section>

    <section class="region3">
        <div class="r3-head">
            <div class="r3-title">账单记录</div>
            <div class="r3-count">@BillItems.Count 条</div>
        </div>

        <div class="records-scroll"
             @ref="RecordsScrollRef"
             @onpointerdown="HandleListPointerDown"
             @onpointermove="HandleListPointerMove"
             @onpointerup="HandleListPointerUp"
             @onpointerleave="HandleListPointerUp"
             @onpointercancel="HandleListPointerUp">

            <div class="pull-holder" style="height:@($"{Math.Max(PullDistance, IsRefreshingList ? 46 : 0)}px")">
                <div class="pull-text">
                    @if (IsRefreshingList)
                    {
                        <span>刷新中...</span>
                    }
                    else if (PullDistance > 56)
                    {
                        <span>松开刷新</span>
                    }
                    else if (PullDistance > 0)
                    {
                        <span>下拉刷新</span>
                    }
                </div>
            </div>

            @if (IsLoading)
            {
                <div class="empty-box">加载中...</div>
            }
            else if (BillItems.Count == 0)
            {
                <div class="empty-box">当前时间范围没有账单</div>
            }
            else
            {
                @foreach (var group in GroupedBills)
                {
                    <section class="day-group">
                        <div class="day-bar @GetDayBarClass(group.Date)">
                            <div class="day-left">
                                <div class="day-title">@GetDayTitle(group.Date)</div>
                                <div class="day-sub">@GetWeekText(group.Date)</div>
                            </div>

                            <div class="day-right">
                                <div class="day-summary">收 @Fmt(group.Income) / 支 @Fmt(group.Expense)</div>
                                <div class="day-count">共 @group.Items.Count 条</div>
                            </div>
                        </div>

                        @foreach (var bill in group.Items)
                        {
                            <div class="swipe-shell
                                @(bill.MarkedPayerRoleId > 0 ? "marked" : "")
                                @(bill.IsExtra ? "extra" : "")
                                @GetShellStateClass(bill.Id)
                                @(HighlightedBillId == bill.Id ? "highlight-active" : "")">
                                <div class="side-panel left-panel">
                                    @if (bill.MarkedPayerRoleId > 0)
                                    {
                                        <button class="action-btn mark-cancel"
                                                @onclick:stopPropagation="true"
                                                @onclick="@(() => CancelMarkAsync(bill.Id))">
                                            取消标记
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="action-btn mark"
                                                @onclick:stopPropagation="true"
                                                @onclick="@(() => OpenMarkSheet(bill))">
                                            标记
                                        </button>
                                    }
                                </div>

                                <article class="bill-row"
                                         style="@GetRowTransformStyle(bill.Id)"
                                         @onpointerdown="e => HandleRowPointerDown(bill.Id, e)"
                                         @onpointermove="e => HandleRowPointerMove(bill.Id, e)"
                                         @onpointerup="e => HandleRowPointerUp(bill.Id, e)">
                                    <div class="bill-main-top">
                                        <div class="bill-title">@GetTitle(bill)</div>

                                        <div class="bill-category-line">
                                            <span class="category-chip main">@GetMainCategoryName(bill.MainCategoryId)</span>
                                            @if (bill.SubCategoryId.HasValue && bill.SubCategoryId.Value > 0 && HasSubCategoryName(bill.SubCategoryId.Value))
                                            {
                                                <span class="category-chip sub">@GetSubCategoryName(bill.SubCategoryId.Value)</span>
                                            }
                                            @if (bill.MarkedPayerRoleId > 0)
                                            {
                                                <span class="category-chip mark-chip">标记：@GetRoleName(bill.MarkedPayerRoleId)</span>
                                            }
                                            @if (bill.IsExtra)
                                            {
                                                <span class="category-chip extra-chip">额外</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="bill-amount @(bill.IoType == 1 ? "expense" : "income")">
                                        @(bill.IoType == 1 ? "-" : "+")@Fmt(bill.Amount)
                                    </div>

                                    <div class="bill-meta-row">
                                        <div class="meta-left">
                                            <span>所属：@GetRoleName(bill.OwnerRoleId)</span>
                                            <span>付款：@GetRoleName(bill.PayerRoleId)</span>
                                        </div>
                                        <div class="meta-right">
                                            <span>记录：@GetUserName(bill.CreatedBy)</span>
                                            <span>更新：@GetUserName(bill.UpdatedBy)</span>
                                        </div>
                                    </div>
                                </article>

                                <div class="side-panel right-panel">
                                    <button class="action-btn edit"
                                            @onclick="() => OpenEditBill(bill)">
                                        编辑
                                    </button>
                                    <button class="action-btn delete"
                                            @onclick:stopPropagation="true"
                                            @onclick="@(() => DeleteBillAsync(bill.Id))">
                                        删除
                                    </button>
                                </div>
                            </div>
                        }
                    </section>
                }
            }
        </div>
    </section>

    @if (ShowMarkRoleSheet && MarkSheetBill is not null)
    {
        <div class="sheet-mask" @onclick="CloseMarkSheet"></div>
        <div class="mark-sheet">
            <div class="sheet-title">标记实际付款方/收款方</div>
            <div class="sheet-subtitle">当前付款：@GetRoleName(MarkSheetBill.PayerRoleId)</div>

            <div class="sheet-role-list">
                @foreach (var role in GetMarkCandidates(MarkSheetBill))
                {
                    <button class="sheet-role-btn" @onclick="@(() => MarkToRoleAsync(MarkSheetBill.Id, role.Id))">
                        @role.Name
                    </button>
                }
            </div>

            <button class="sheet-cancel-btn" @onclick="CloseMarkSheet">取消</button>
        </div>
    }

    @if (ShowToast)
    {
        <div class="toast-box">@ToastMessage</div>
    }

    @if (ShowEditor)
    {
        <BillEditor BillId="EditingBillId"
                    InitialDate="InitialDateForAdd"
                    OnSaved="HandleEditorSaved"
                    OnCanceled="CloseEditor" />
    }
</div>
