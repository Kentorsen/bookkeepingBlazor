@page "/bill/add"
@using BookkeepingBlazor.Models
@using BookkeepingBlazor.Services
@inject SupabaseService Supabase
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="editor-app">
    <header class="editor-header">
        <button class="nav-btn" @onclick="GoBack">取消</button>
        
        <div class="type-switcher">
            <button class="switch-btn @(Model.IoType == 1 ? "active" : "")"
                    @onclick="() => SetIoType(1)">
                支出
            </button>
            <button class="switch-btn @(Model.IoType == 2 ? "active" : "")"
                    @onclick="() => SetIoType(2)">
                收入
            </button>
        </div>
        
        <button class="nav-btn primary" @onclick="SaveBillAsync">保存</button>
    </header>

    <div class="editor-content">
        <section class="form-section amount-section">
            <div class="amount-wrapper @(Model.IoType == 1 ? "expense" : "income")">
                <span class="currency">¥</span>
                <input type="number" inputmode="decimal" class="amount-input"
                       placeholder="0.00" @bind="Model.Amount" />
            </div>
        </section>

        <section class="form-section">
            <div class="section-header">
                <div class="section-title">分类</div>
                <button class="edit-text-btn" @onclick='() => ShowToast("分类编辑功能开发中...")'>编辑分类</button>
            </div>
            
            <div class="category-grid">
                @foreach (var cat in MainCategories.Where(c => c.Type == Model.IoType))
                {
                    <button class="chip @(Model.MainCategoryId == cat.Id ? "active" : "")"
                            @onclick="() => SelectMainCategory(cat.Id)" title="@cat.Name">
                        @cat.Name
                    </button>
                }
            </div>

            @if (Model.MainCategoryId > 0 && SubCategories.Any(x => x.MainCategoryId == Model.MainCategoryId))
            {
                <div class="sub-category-grid">
                    @foreach (var sub in SubCategories.Where(x => x.MainCategoryId == Model.MainCategoryId))
                    {
                        <button class="chip sub @(Model.SubCategoryId == sub.Id ? "active" : "")"
                                @onclick="() => SelectSubCategory(sub.Id)" title="@sub.Name">
                            @sub.Name
                        </button>
                    }
                </div>
            }
        </section>

        <section class="form-section list-section">
            <div class="form-row">
                <label>日期</label>
                <input type="date" class="row-input" @bind="Model.BillDate" @bind:format="yyyy-MM-dd" />
            </div>
            
            <div class="form-row column-layout">
                <div class="name-input-row">
                    <label>名称</label>
                    <input type="text" class="row-input" placeholder="输入账单名称" @bind="Model.Title" />
                </div>
                <div class="quick-fill-tags">
                    <span class="q-tag" @onclick="() => FillName(1)">填主类</span>
                    <span class="q-tag" @onclick="() => FillName(2)">填子类</span>
                    <span class="q-tag" @onclick="() => FillName(3)">主类 + 子类</span>
                </div>
            </div>

            <div class="form-row">
                <label>额外</label>
                <label class="toggle-switch">
                    <input type="checkbox" @bind="Model.IsExtra" />
                    <span class="slider"></span>
                </label>
            </div>
        </section>

        <section class="form-section list-section">
            <div class="form-row column-layout">
                <label>所属方</label>
                <div class="chip-row">
                    @foreach (var role in Roles)
                    {
                        <button class="chip small @(Model.OwnerRoleId == role.Id ? "active" : "")"
                                @onclick="() => Model.OwnerRoleId = role.Id">
                            @role.Name
                        </button>
                    }
                </div>
            </div>

            <div class="form-row column-layout">
                <label>@(Model.IoType == 1 ? "付款方" : "收款方")</label>
                <div class="chip-row">
                    @foreach (var role in Roles.Where(r => r.RoleType != "pet"))
                    {
                        <button class="chip small @(Model.PayerRoleId == role.Id ? "active" : "")"
                                @onclick="() => SetPayer(role.Id)">
                            @role.Name
                        </button>
                    }
                </div>
            </div>

            <div class="form-row column-layout">
                <label>标记</label>
                <div class="chip-row">
                    <button class="chip small @(Model.MarkedPayerRoleId == 0 ? "active" : "")"
                            @onclick="() => Model.MarkedPayerRoleId = 0">
                        无
                    </button>
                    
                    @foreach (var role in Roles.Where(r => r.RoleType != "pet" && r.Id != Model.PayerRoleId))
                    {
                        <button class="chip small @(Model.MarkedPayerRoleId == role.Id ? "active" : "")"
                                @onclick="() => Model.MarkedPayerRoleId = role.Id">
                            @role.Name
                        </button>
                    }
                </div>
            </div>
        </section>
    </div>

    @if (ShowToastFlag)
    {
        <div class="toast-box">@ToastMessage</div>
    }
</div>

@code {
    private Bill Model = new Bill();
    private List<RoleInfo> Roles = new();
    private List<MainCategoryInfo> MainCategories = new();
    private List<SubCategoryInfo> SubCategories = new();
    
    private bool ShowToastFlag;
    private string ToastMessage = "";

    protected override async Task OnInitializedAsync()
    {
        Roles = await Supabase.GetRolesAsync();
        MainCategories = await Supabase.GetMainCategoriesAsync();
        SubCategories = await Supabase.GetSubCategoriesAsync();

        Model.IoType = 1;
        Model.IsExtra = false;
        Model.BillDate = DateTime.Today;
        Model.MarkedPayerRoleId = 0;

        var sharedRole = Roles.FirstOrDefault(r => r.RoleType == "group") ?? Roles.FirstOrDefault();
        if (sharedRole != null)
        {
            Model.OwnerRoleId = sharedRole.Id;
            Model.PayerRoleId = sharedRole.Id;
        }
    }

    private void SetIoType(short type)
    {
        Model.IoType = type;
        Model.MainCategoryId = 0;
        Model.SubCategoryId = null;
    }

    private void SelectMainCategory(long id)
    {
        Model.MainCategoryId = id;
        Model.SubCategoryId = null;
    }

    private void SelectSubCategory(long id) => Model.SubCategoryId = id;

    private void SetPayer(long roleId)
    {
        Model.PayerRoleId = roleId;
        if (Model.MarkedPayerRoleId == roleId)
        {
            Model.MarkedPayerRoleId = 0;
        }
    }

    // 快捷填充名称的方法
    private void FillName(int mode)
    {
        if (Model.MainCategoryId == 0)
        {
            ShowToast("请先选择分类");
            return;
        }

        var mainName = MainCategories.FirstOrDefault(c => c.Id == Model.MainCategoryId)?.Name ?? "";
        var subName = SubCategories.FirstOrDefault(c => c.Id == Model.SubCategoryId)?.Name ?? "";

        if (mode == 1)
        {
            Model.Title = mainName;
        }
        else if (mode == 2)
        {
            if (string.IsNullOrEmpty(subName)) ShowToast("当前未选择子类别");
            else Model.Title = subName;
        }
        else if (mode == 3)
        {
            if (string.IsNullOrEmpty(subName)) Model.Title = mainName;
            else Model.Title = $"{mainName} {subName}"; // 中间加半角空格
        }
    }

    private async Task SaveBillAsync()
    {
        // 1. 金额校验 (不能为 0)
        if (Model.Amount == 0)
        {
            ShowToast("金额不能为 0");
            return;
        }

        // 2. 主类别校验
        if (Model.MainCategoryId == 0)
        {
            ShowToast("请选择主类别");
            return;
        }

        // 3. 日期校验
        if (Model.BillDate == null || Model.BillDate == default(DateTime))
        {
            ShowToast("日期不能为空");
            return;
        }

        // 4. 名称校验
        if (string.IsNullOrWhiteSpace(Model.Title))
        {
            ShowToast("名称不能为空");
            return;
        }

        // 5. 所属方校验
        if (Model.OwnerRoleId == 0)
        {
            ShowToast("请选择所属方");
            return;
        }

        // 6. 付款方校验
        if (Model.PayerRoleId == 0)
        {
            ShowToast("请选择付款方/收款方");
            return;
        }

        // 7. 标记合法性校验（虽然 UI 限定了不能乱填，但防御性检查，且 0 是合法的“无”）
        if (Model.MarkedPayerRoleId < 0)
        {
            ShowToast("标记信息有误");
            return;
        }

        // 设置审计字段默认值，写死 id = 1
        Model.CreatedAt = DateTime.UtcNow;
        Model.CreatedBy = 1;
        Model.UpdatedAt = DateTime.UtcNow;
        Model.UpdatedBy = 1;
        Model.IsDeleted = false;

        try
        {
            await Supabase.InsertBillAsync(Model);
            Nav.NavigateTo("/bills");
        }
        catch (Exception ex)
        {
            ShowToast("保存失败: " + ex.Message);
        }
    }

    private void GoBack() => Nav.NavigateTo("/bills");

    private async void ShowToast(string message)
    {
        ToastMessage = message;
        ShowToastFlag = true;
        StateHasChanged();
        await Task.Delay(2000);
        ShowToastFlag = false;
        StateHasChanged();
    }
}