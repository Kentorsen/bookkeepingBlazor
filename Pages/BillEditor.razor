@using BookkeepingBlazor.Models
@using BookkeepingBlazor.Services
@inject SupabaseService Supabase
@inject IJSRuntime JS

<div class="editor-app">
    <header class="editor-header">
        <div class="editor-mode-indicator">
            @(BillId.HasValue && BillId.Value > 0 ? "当前：编辑账单" : "当前：添加账单")
        </div>

        <button class="nav-btn" @onclick="GoBack">取消</button>
        
        <div class="type-switcher">
            <button class="switch-btn @(Model.IoType == 1 ? "active" : "")"
                    @onclick="() => SetIoType(1)">
                支出
            </button>
            <button class="switch-btn @(Model.IoType == 2 ? "active" : "")"
                    @onclick="() => SetIoType(2)">
                收入
            </button>
        </div>
        
        <button class="nav-btn primary" @onclick="SaveBillAsync">保存</button>
    </header>

    <div class="editor-content">
        <section class="form-section amount-section">
            <div class="amount-wrapper @(Model.IoType == 1 ? "expense" : "income")">
                <span class="currency">¥</span>
                <input type="number" inputmode="decimal" class="amount-input"
                       placeholder="0.00" @bind="Model.Amount" />
            </div>
        </section>

        <section class="form-section">
            <div class="section-header">
                <div class="section-title">分类</div>
                <div class="hint-text">💡 再次点击已选中的分类即可编辑</div>
            </div>
            
            <div class="category-grid">
                @foreach (var cat in MainCategories.Where(c => c.Type == Model.IoType && !c.IsDeleted))
                {
                    <button class="chip @(Model.MainCategoryId == cat.Id ? "active" : "")"
                            @onclick="() => HandleMainCategoryClick(cat.Id)" title="@cat.Name">
                        @cat.Name
                    </button>
                }
                <button class="chip chip-add" @onclick="OpenAddMainCategory">+ 添加</button>
            </div>

            @if (Model.MainCategoryId > 0)
            {
                <div class="sub-category-grid">
                    @foreach (var sub in SubCategories.Where(x => x.MainCategoryId == Model.MainCategoryId && !x.IsDeleted))
                    {
                        <button class="chip sub @(Model.SubCategoryId == sub.Id ? "active" : "")"
                                @onclick="() => HandleSubCategoryClick(sub.Id)" title="@sub.Name">
                            @sub.Name
                        </button>
                    }
                    <button class="chip sub chip-add" @onclick="() => OpenAddSubCategory(Model.MainCategoryId)">+ 添加</button>
                </div>
            }
        </section>

        <section class="form-section list-section">
            <div class="form-row">
                <label>日期</label>
                <input type="date" class="row-input" @bind="Model.BillDate" @bind:format="yyyy-MM-dd" />
            </div>
            
            <div class="form-row column-layout">
                <div class="name-input-row">
                    <label>名称</label>
                    <input type="text" class="row-input" placeholder="输入账单名称" @bind="Model.Title" />
                </div>
                <div class="quick-fill-tags">
                    <span class="q-tag" @onclick="() => FillName(1)">填主类</span>
                    <span class="q-tag" @onclick="() => FillName(2)">填子类</span>
                    <span class="q-tag" @onclick="() => FillName(3)">主类 + 子类</span>
                </div>
            </div>

            <div class="form-row">
                <label>额外</label>
                <label class="toggle-switch">
                    <input type="checkbox" @bind="Model.IsExtra" />
                    <span class="slider"></span>
                </label>
            </div>
        </section>

        <section class="form-section list-section">
            <div class="form-row column-layout">
                <label>所属方</label>
                <div class="chip-row">
                    @foreach (var role in Roles)
                    {
                        <button class="chip small @(Model.OwnerRoleId == role.Id ? "active" : "")"
                                @onclick="() => Model.OwnerRoleId = role.Id">
                            @role.Name
                        </button>
                    }
                </div>
            </div>

            <div class="form-row column-layout">
                <label>@(Model.IoType == 1 ? "付款方" : "收款方")</label>
                <div class="chip-row">
                    @foreach (var role in Roles.Where(r => r.RoleType != "pet"))
                    {
                        <button class="chip small @(Model.PayerRoleId == role.Id ? "active" : "")"
                                @onclick="() => SetPayer(role.Id)">
                            @role.Name
                        </button>
                    }
                </div>
            </div>

            <div class="form-row column-layout">
                <label>标记</label>
                <div class="chip-row">
                    <button class="chip small @(Model.MarkedPayerRoleId == 0 ? "active" : "")"
                            @onclick="() => Model.MarkedPayerRoleId = 0">
                        无
                    </button>
                    
                    @foreach (var role in Roles.Where(r => r.RoleType != "pet" && r.Id != Model.PayerRoleId))
                    {
                        <button class="chip small @(Model.MarkedPayerRoleId == role.Id ? "active" : "")"
                                @onclick="() => Model.MarkedPayerRoleId = role.Id">
                            @role.Name
                        </button>
                    }
                </div>
            </div>
        </section>
    </div>

    @if (ShowCatInputDialog)
    {
        <div class="dialog-mask" @onclick="CloseCatInput"></div>
        <div class="input-dialog">
            <div class="dialog-title">@CatInputTitle</div>
            <input type="text" class="dialog-input" placeholder="请输入名称" @bind="CatInputName" />
            
            <div class="dialog-footer @(CatInputMode == 2 || CatInputMode == 4 ? "has-delete" : "")">
                @if (CatInputMode == 2 || CatInputMode == 4)
                {
                    <button class="dialog-btn danger" @onclick="DeleteCurrentCategory">删除</button>
                }
                <button class="dialog-btn" @onclick="CloseCatInput">取消</button>
                <button class="dialog-btn primary" @onclick="ConfirmCatInput">确定</button>
            </div>
        </div>
    }

    @if (ShowToastFlag)
    {
        <div class="toast-box">@ToastMessage</div>
    }
</div>

@code {
    // 💡 新增的组件交互参数
    [Parameter] public long? BillId { get; set; }
    [Parameter] public DateTime InitialDate { get; set; } = DateTime.Today; // 💡 新增参数
    [Parameter] public EventCallback<Bill> OnSaved { get; set; }
    [Parameter] public EventCallback OnCanceled { get; set; }

    private Bill Model = new Bill();
    private List<RoleInfo> Roles = new();
    private List<MainCategoryInfo> MainCategories = new();
    private List<SubCategoryInfo> SubCategories = new();

    private bool ShowToastFlag;
    private string ToastMessage = "";

    private bool ShowCatInputDialog = false;
    private string CatInputName = "";
    private string CatInputTitle = "";
    private int CatInputMode = 0;
    private long EditingCatId = 0;
    private long TargetMainCatId = 0;

    protected override async Task OnInitializedAsync()
    {
        Roles = await Supabase.GetRolesAsync();
        MainCategories = await Supabase.GetMainCategoriesAsync();
        SubCategories = await Supabase.GetSubCategoriesAsync();

        // 💡 如果传入了 ID，则是【编辑模式】，去数据库查出现存数据
        if (BillId.HasValue && BillId.Value > 0)
        {
            var dbBill = await Supabase.GetBillByIdAsync(BillId.Value);
            if (dbBill != null)
            {
                Model = dbBill;
            }
        }
        else
        {
            // 【新增模式】：设定默认值
            Model.IoType = 1;
            Model.IsExtra = false;
            Model.BillDate = InitialDate;
            Model.MarkedPayerRoleId = 0;

            var sharedRole = Roles.FirstOrDefault(r => r.RoleType == "group") ?? Roles.FirstOrDefault();
            if (sharedRole != null)
            {
                Model.OwnerRoleId = sharedRole.Id;
                Model.PayerRoleId = sharedRole.Id;
            }
        }
    }

    private void SetIoType(short type)
    {
        Model.IoType = type;
        Model.MainCategoryId = 0;
        Model.SubCategoryId = null;
    }

    private void HandleMainCategoryClick(long id)
    {
        if (Model.MainCategoryId == id)
        {
            var cat = MainCategories.FirstOrDefault(c => c.Id == id);
            if (cat != null) OpenEditMainCategory(cat);
        }
        else
        {
            Model.MainCategoryId = id;
            Model.SubCategoryId = null;
        }
    }

    private void HandleSubCategoryClick(long id)
    {
        if (Model.SubCategoryId == id)
        {
            var sub = SubCategories.FirstOrDefault(s => s.Id == id);
            if (sub != null) OpenEditSubCategory(sub);
        }
        else
        {
            Model.SubCategoryId = id;
        }
    }

    private void SetPayer(long roleId)
    {
        Model.PayerRoleId = roleId;
        if (Model.MarkedPayerRoleId == roleId) Model.MarkedPayerRoleId = 0;
    }

    private void FillName(int mode)
    {
        if (Model.MainCategoryId == 0) { ShowToast("请先选择分类"); return; }
        var mainName = MainCategories.FirstOrDefault(c => c.Id == Model.MainCategoryId)?.Name ?? "";
        var subName = SubCategories.FirstOrDefault(c => c.Id == Model.SubCategoryId)?.Name ?? "";

        if (mode == 1) Model.Title = mainName;
        else if (mode == 2)
        {
            if (string.IsNullOrEmpty(subName)) ShowToast("当前未选择子类别");
            else Model.Title = subName;
        }
        else if (mode == 3)
        {
            if (string.IsNullOrEmpty(subName)) Model.Title = mainName;
            else Model.Title = $"{mainName} {subName}";
        }
    }

    private async Task SaveBillAsync()
    {
        if (Model.Amount <= 0) { ShowToast("金额必须大于 0"); return; }
        if (Model.MainCategoryId == 0) { ShowToast("请选择主类别"); return; }
        if (Model.BillDate == null || Model.BillDate == default(DateTime)) { ShowToast("日期不能为空"); return; }
        if (string.IsNullOrWhiteSpace(Model.Title)) { ShowToast("名称不能为空"); return; }
        if (Model.OwnerRoleId == 0) { ShowToast("请选择所属方"); return; }
        if (Model.PayerRoleId == 0) { ShowToast("请选择付款方/收款方"); return; }
        if (Model.MarkedPayerRoleId < 0) { ShowToast("标记信息有误"); return; }

        try
        {
            // 💡 1. 在保存前，先去管家那里问出当前是谁在操作
            var currentUserId = await Supabase.GetCurrentAppUserIdAsync();
            if (currentUserId == 0)
            {
                ShowToast("获取用户身份失败，请检查邮箱是否在 users 表中");
                return;
            }

            Bill savedBill;
            if (BillId.HasValue && BillId.Value > 0)
            {
                // 执行更新
                Model.UpdatedAt = DateTime.UtcNow;
                Model.UpdatedBy = currentUserId; // 💡 动态赋值更新者
                await Supabase.UpdateBillAsync(Model);
                savedBill = Model;
            }
            else
            {
                // 执行新增
                Model.CreatedAt = DateTime.UtcNow;
                Model.CreatedBy = currentUserId; // 💡 动态赋值创建者
                Model.UpdatedAt = DateTime.UtcNow;
                Model.UpdatedBy = currentUserId; // 💡 动态赋值更新者
                Model.IsDeleted = false;
                
                var newBill = await Supabase.InsertBillAsync(Model);
                savedBill = newBill ?? Model;
            }

            await OnSaved.InvokeAsync(savedBill);
        }
        catch (Exception ex)
        {
            ShowToast("保存失败: " + ex.Message);
        }
    }

    private async Task GoBack()
    {
        // 💡 通知父组件取消操作，关闭弹层
        await OnCanceled.InvokeAsync();
    }

    private async void ShowToast(string message)
    {
        ToastMessage = message;
        ShowToastFlag = true;
        StateHasChanged();
        await Task.Delay(2000);
        ShowToastFlag = false;
        StateHasChanged();
    }

    // 分类增删改逻辑 (保持不变)
    private void OpenAddMainCategory() { CatInputMode = 1; CatInputTitle = "新增主分类"; CatInputName = ""; ShowCatInputDialog = true; }
    private void OpenEditMainCategory(MainCategoryInfo cat) { CatInputMode = 2; CatInputTitle = "编辑主分类"; CatInputName = cat.Name ?? ""; EditingCatId = cat.Id; ShowCatInputDialog = true; }
    private void OpenAddSubCategory(long mainCatId) { CatInputMode = 3; CatInputTitle = "新增子分类"; CatInputName = ""; TargetMainCatId = mainCatId; ShowCatInputDialog = true; }
    private void OpenEditSubCategory(SubCategoryInfo sub) { CatInputMode = 4; CatInputTitle = "编辑子分类"; CatInputName = sub.Name ?? ""; EditingCatId = sub.Id; ShowCatInputDialog = true; }
    private void CloseCatInput() => ShowCatInputDialog = false;

    private async Task ConfirmCatInput()
    {
        if (string.IsNullOrWhiteSpace(CatInputName)) { ShowToast("名称不能为空"); return; }
        try
        {
            if (CatInputMode == 1)
            {
                var newCat = await Supabase.InsertMainCategoryAsync(new MainCategoryInfo { Name = CatInputName, Type = Model.IoType });
                if (newCat != null) { MainCategories.Add(newCat); Model.MainCategoryId = newCat.Id; ShowToast("已新增主分类"); }
            }
            else if (CatInputMode == 2)
            {
                await Supabase.UpdateMainCategoryAsync(EditingCatId, CatInputName);
                var cat = MainCategories.FirstOrDefault(c => c.Id == EditingCatId);
                if (cat != null) cat.Name = CatInputName; ShowToast("已修改主分类");
            }
            else if (CatInputMode == 3)
            {
                var newSub = await Supabase.InsertSubCategoryAsync(new SubCategoryInfo { MainCategoryId = TargetMainCatId, Name = CatInputName });
                if (newSub != null) { SubCategories.Add(newSub); Model.SubCategoryId = newSub.Id; ShowToast("已新增子分类"); }
            }
            else if (CatInputMode == 4)
            {
                await Supabase.UpdateSubCategoryAsync(EditingCatId, CatInputName);
                var sub = SubCategories.FirstOrDefault(s => s.Id == EditingCatId);
                if (sub != null) sub.Name = CatInputName; ShowToast("已修改子分类");
            }
        }
        catch (Exception ex) { ShowToast("操作失败: " + ex.Message); }
        CloseCatInput();
    }

    private async Task DeleteCurrentCategory()
    {
        try
        {
            if (CatInputMode == 2)
            {
                await Supabase.SoftDeleteMainCategoryAsync(EditingCatId);
                await Supabase.SoftDeleteSubCategoriesByMainIdAsync(EditingCatId);
                var cat = MainCategories.FirstOrDefault(c => c.Id == EditingCatId);
                if (cat != null) cat.IsDeleted = true;
                var relatedSubs = SubCategories.Where(s => s.MainCategoryId == EditingCatId).ToList();
                foreach (var sub in relatedSubs) { sub.IsDeleted = true; }
                Model.MainCategoryId = 0; Model.SubCategoryId = null; ShowToast("已删除主分类及其子分类");
            }
            else if (CatInputMode == 4)
            {
                await Supabase.SoftDeleteSubCategoryAsync(EditingCatId);
                var sub = SubCategories.FirstOrDefault(s => s.Id == EditingCatId);
                if (sub != null) sub.IsDeleted = true;
                Model.SubCategoryId = null; ShowToast("已删除子分类");
            }
        }
        catch (Exception ex) { ShowToast("删除失败: " + ex.Message); }
        CloseCatInput();
    }
}