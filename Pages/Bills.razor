@page "/"
@page "/bills"
@using BookkeepingBlazor.Components.Bills

<div class="bill-shell">
    <BillsHomeView @ref="HomeViewRef" />

    <footer class="bottom-action-bar">
        <button class="bar-btn" @onclick="ShowStatsPlaceholderAsync">统计</button>
        <button class="bar-btn" @onclick="RefreshBillsAsync">刷新</button>
        <button class="add-btn" @onclick="OpenAddBillAsync" aria-label="添加">＋</button>
        <button class="bar-btn" @onclick="ShowFilterPlaceholderAsync">筛选</button>
        <button class="bar-btn" @onclick="ShowMorePlaceholderAsync">更多</button>
    </footer>
</div>

@code {
    private BillsHomeView? HomeViewRef;

    private async Task RefreshBillsAsync()
    {
        if (HomeViewRef is null) return;
        await HomeViewRef.RefreshFromShellAsync();
    }

    private async Task OpenAddBillAsync()
    {
        if (HomeViewRef is null) return;
        await HomeViewRef.OpenAddFromShellAsync();
    }

    private async Task ShowStatsPlaceholderAsync()
    {
        if (HomeViewRef is null) return;
        await HomeViewRef.ShowShellToastAsync("统计画面后续接");
    }

    private async Task ShowFilterPlaceholderAsync()
    {
        if (HomeViewRef is null) return;
        await HomeViewRef.ShowShellToastAsync("筛选功能后续接");
    }

    private async Task ShowMorePlaceholderAsync()
    {
        if (HomeViewRef is null) return;
        await HomeViewRef.ShowShellToastAsync("更多功能后续接");
    }
}