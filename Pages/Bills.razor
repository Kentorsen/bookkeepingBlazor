@page "/bills"
@using BookkeepingBlazor.Models
@inject BookkeepingBlazor.Services.SupabaseService Supabase

<h3>账单列表</h3>

@if (bills == null)
{
    <p>加载中...</p>
}
else if (bills.Count == 0)
{
    <p>暂时没有账单。</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>日期</th>
                <th>标题</th>
                <th>金额</th>
                <th>类型</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in bills)
            {
                <tr>
                    <td>@(b.BillDate?.ToString("yyyy-MM-dd"))</td>
                    <td>@b.Title</td>
                    <td>@b.Amount</td>
                    <td>@(b.IoType == 1 ? "支出" : "收入")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Bill>? bills;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            bills = await Supabase.GetBillsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            bills = new();
        }
    }
}